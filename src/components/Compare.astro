---
import { useTranslations } from '../i18n/utils';
export interface Props { lang: 'en' | 'fr' | 'ko'; }
const { lang } = Astro.props;
const t = useTranslations(lang);

// Columns = 4 service offerings
// Rows = capabilities
// ● full  ◐ partial  – none
const matrix = [
  // [Audit, Strategy, Dev, Workshop]
  ['●', '◐', '–', '–'],  // Assessment & Diagnosis
  ['●', '●', '–', '–'],  // Strategic Roadmap
  ['–', '◐', '●', '–'],  // Custom AI Development
  ['–', '–', '◐', '●'],  // Team Training
  ['–', '–', '●', '–'],  // Ongoing Maintenance
  ['◐', '●', '–', '–'],  // AI Governance
];
---
<section id="compare" style="background:var(--grey)">
  <span class="section-label reveal">{t('cmp.label')}</span>
  <h2 class="section-title reveal">{t('cmp.title')}</h2>
  <p class="section-desc reveal">{t('cmp.desc')}</p>
  <div class="reveal" style="overflow-x:auto;margin-top:40px">
    <table class="cmp-table">
      <thead>
        <tr>
          <th>{t('cmp.service')}</th>
          <th>{t('svc1.title')}</th>
          <th>{t('svc2.title')}</th>
          <th>{t('svc3.title')}</th>
          <th>{t('svc4.title')}</th>
        </tr>
      </thead>
      <tbody>
        {matrix.map((row, i) => (
          <tr>
            <td>{t(`cmp.row${i + 1}`)}</td>
            {row.map(cell => (
              <td class={cell === '●' ? 'cmp-full' : cell === '◐' ? 'cmp-half' : 'cmp-none'}>{cell}</td>
            ))}
          </tr>
        ))}
      </tbody>
    </table>
    <p class="reveal" style="text-align:center;margin-top:16px;font-size:0.8rem;color:var(--text-muted)" set:html={t('cmp.legend')} />
  </div>
</section>
