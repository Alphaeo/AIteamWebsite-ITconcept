  <Services lang={lang} />
  <Stack lang={lang} />
  <POCs lang={lang} />
  <Packages lang={lang} />
  <Compare lang={lang} />
  <FAQ lang={lang} />
  <Team lang={lang} />
  <Certifications lang={lang} />
  <Testimonials lang={lang} />
  <Contact lang={lang} />
  <Company lang={lang} />
</BaseLayout>
