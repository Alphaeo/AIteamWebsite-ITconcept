---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import Positioning from '../components/Positioning.astro';
import Process from '../components/Process.astro';
import Services from '../components/Services.astro';
import Stack from '../components/Stack.astro';
import POCs from '../components/POCs.astro';
import Packages from '../components/Packages.astro';
import Compare from '../components/Compare.astro';
import FAQ from '../components/FAQ.astro';
import Team from '../components/Team.astro';
import Certifications from '../components/Certifications.astro';
import Testimonials from '../components/Testimonials.astro';
import Contact from '../components/Contact.astro';
import Company from '../components/Company.astro';

const lang = 'en';
